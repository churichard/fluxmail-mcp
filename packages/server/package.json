{
  "name": "fluxmail",
  "version": "0.1.0",
  "description": "Fluxmail MCP server: unified email tools over Gmail and IMAP/SMTP",
  "homepage": "https://github.com/churichard/fluxmail-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/churichard/fluxmail-mcp.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/churichard/fluxmail-mcp/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fluxmail": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@fluxmail/core": "workspace:*",
    "@fluxmail/provider-gmail": "workspace:*",
    "@fluxmail/provider-imap": "workspace:*",
    "@hono/node-server": "^1.14.3",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "better-sqlite3": "^11.10.0",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "10.5.0",
    "hono": "^4.7.11",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "imapflow": "^1.4.7"
  }
}
