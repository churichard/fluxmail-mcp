{
  "name": "fluxmail",
  "version": "0.5.0",
  "mcpName": "io.github.churichard/fluxmail",
  "description": "Self-hosted email API with MCP and REST support for Gmail, Outlook, and IMAP/SMTP",
  "keywords": [
    "email",
    "email-api",
    "email-automation",
    "emailengine",
    "email-engine",
    "mail",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai",
    "ai-agents",
    "gmail",
    "gmail-api",
    "outlook",
    "microsoft-365",
    "office-365",
    "microsoft-graph",
    "imap",
    "smtp",
    "self-hosted",
    "rest-api",
    "api",
    "openapi",
    "cli",
    "typescript"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/churichard/fluxmail#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/churichard/fluxmail.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/churichard/fluxmail/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fluxmail": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^20.20.0 || >=22.22.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@fluxmail/core": "workspace:*",
    "@fluxmail/provider-gmail": "workspace:*",
    "@fluxmail/provider-imap": "workspace:*",
    "@fluxmail/provider-outlook": "workspace:*",
    "@hono/node-server": "^1.14.3",
    "@hono/zod-openapi": "0.19.10",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@node-rs/argon2": "2.0.2",
    "better-sqlite3": "^11.10.0",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "10.5.0",
    "hono": "^4.7.11",
    "posthog-node": "^5.41.0",
    "update-notifier": "7.3.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/update-notifier": "6.0.8",
    "imapflow": "^1.4.7"
  }
}
