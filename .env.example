# Docker Compose loads this file into the Fluxmail process environment.
# Restart the container after changing deployment settings.

# Public HTTP server
# FLUXMAIL_PORT=8977
# FLUXMAIL_PUBLIC_URL=https://mail.example.com
# FLUXMAIL_TRUST_PROXY=1

# Storage
# FLUXMAIL_DATA_DIR=/data
# FLUXMAIL_DB_PATH=/data/fluxmail.db
# FLUXMAIL_ENCRYPTION_KEY_FILE=/run/secrets/fluxmail_encryption_key

# Local OAuth callback listener
# FLUXMAIL_OAUTH_PORT=8976
# FLUXMAIL_OAUTH_HOST=0.0.0.0

# Limits and telemetry
# FLUXMAIL_MAX_ATTACHMENT_MB=10
# FLUXMAIL_TELEMETRY=0

# OAuth applications are normally configured with `fluxmail oauth configure`
# and stored encrypted in SQLite. Managed deployments can override complete
# provider groups through the environment.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET_FILE=/run/secrets/google_client_secret
# MICROSOFT_CLIENT_ID=
# MICROSOFT_TENANT_ID=common
# MICROSOFT_CLIENT_SECRET_FILE=/run/secrets/microsoft_client_secret

# Licenses are normally configured with `fluxmail license activate`.
# FLUXMAIL_LICENSE_KEY_FILE=/run/secrets/fluxmail_license_key

# IMAP passwords are stored per mailbox. Scripts can pass their own environment
# variable names with --imap-password-env and --smtp-password-env.
# IMAP_PASSWORD=
# SMTP_PASSWORD=
