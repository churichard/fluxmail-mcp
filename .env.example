# Google OAuth credentials (required for Gmail); see README "Google setup"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# IMAP passwords are stored per account by `fluxmail accounts add imap`.
# For a scripted or Docker setup, choose environment variable names and pass
# them with --imap-password-env and --smtp-password-env.
# IMAP_PASSWORD=
# SMTP_PASSWORD=

# Optional
# FLUXMAIL_PORT=8977
# Set this to the public HTTPS address for Docker or remote Gmail setup.
# Register <FLUXMAIL_PUBLIC_URL>/auth/google/callback with Google Cloud.
# FLUXMAIL_PUBLIC_URL=https://mail.example.com
# FLUXMAIL_DATA_DIR=~/.fluxmail
# FLUXMAIL_ENCRYPTION_KEY=   # 64 hex chars; autogenerated on first run if unset
# FLUXMAIL_AUTH=apikey       # or "none" for trusted networks only
# FLUXMAIL_OAUTH_PORT=8976
# FLUXMAIL_OAUTH_HOST=127.0.0.1 # set to 0.0.0.0 only when using the local callback from a container
# FLUXMAIL_MAX_ATTACHMENT_MB=10 # decoded attachment size returned through MCP; maximum 25
# FLUXMAIL_LICENSE_KEY=        # paid-tier license key; usually set via "fluxmail license activate"
