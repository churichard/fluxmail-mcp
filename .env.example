# Google OAuth credentials (required for Gmail); see README "Google setup"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional
# FLUXMAIL_PORT=8977
# FLUXMAIL_BASE_URL=http://localhost:8977
# FLUXMAIL_DATA_DIR=~/.fluxmail
# FLUXMAIL_ENCRYPTION_KEY=   # 64 hex chars; autogenerated on first run if unset
# FLUXMAIL_AUTH=apikey       # or "none" for trusted networks only
# FLUXMAIL_OAUTH_PORT=8976
# FLUXMAIL_OAUTH_HOST=127.0.0.1 # set to 0.0.0.0 only when publishing the callback port from a container
# FLUXMAIL_LICENSE_KEY=        # paid-tier license key; usually set via "fluxmail license activate"
